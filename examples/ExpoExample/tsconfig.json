{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "react-native-nano-icons": [
        "../../packages/react-native-nano-icons/src/index"
      ],
      "react-native-nano-icons/*": [
        "../../packages/react-native-nano-icons/src/*"
      ]
    },
    "resolveJsonModule": true
  },
  "exclude": ["node_modules", "ios", "android", "metro.config.js"]
}
