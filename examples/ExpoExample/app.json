{
  "expo": {
    "name": "react-native-nano-icons-example",
    "slug": "react-native-nano-icons-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "expo.modules.nanoicons.example"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "expo.modules.nanoicons.example"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      [
        "react-native-nano-icons",
        {
          "iconSets": [
            {
              "inputDir": "./assets/testicons",
              "fontFamily": "Testicons",
              "outputDir": "./assets/nanoicons"
            },
            {
              "inputDir": "../../packages/react-native-nano-icons/test_icons/material_icons/twotone",
              "fontFamily": "MaterialIconsTwotone",
              "outputDir": "./assets/nanoicons"
            },
            {
              "inputDir": "../../packages/react-native-nano-icons/test_icons/swm_icons/broken",
              "fontFamily": "SWMIconsBroken",
              "outputDir": "./assets/nanoicons"
            }
          ]
        }
      ],
      "expo-router"
    ]
  }
}
