{
  "name": "react-native-nano-icons-monorepo",
  "private": true,
  "packageManager": "yarn@4.1.1",
  "workspaces": {
    "packages": [
      "packages/*",
      "examples/*"
    ]
  },
  "scripts": {
    "build": "yarn build-packages",
    "build-packages": "yarn workspace react-native-nano-icons build",
    "build:expo:ios": "yarn workspace expo-nano-icons-example ios",
    "build:expo:android": "yarn workspace expo-nano-icons-example android",
    "build:bare:ios": "yarn workspace bare-react-native-nano-icons-example ios",
    "build:bare:android": "yarn workspace bare-react-native-nano-icons-example android",
    "start:bare": "yarn workspace bare-react-native-nano-icons-example start",
    "start:expo": "yarn workspace expo-nano-icons-example start",
    "prebuild": "yarn workspace expo-nano-icons-example expo prebuild --clean",
    "test": "yarn workspace react-native-nano-icons test"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
