{
  "name": "react-native-nano-icons-monorepo",
  "private": true,
  "packageManager": "yarn@4.1.1",
  "workspaces": {
    "packages": [
      "packages/*",
      "examples/*"
    ]
  },
  "scripts": {
    "postinstall": "husky install",
    "build": "yarn build-packages",
    "build-packages": "yarn workspace react-native-nano-icons build",
    "build:expo:ios": "yarn workspace expo-nano-icons-example ios",
    "build:expo:android": "yarn workspace expo-nano-icons-example android",
    "build:bare:ios": "yarn workspace bare-react-native-nano-icons-example ios",
    "build:bare:ios:release": "yarn workspace bare-react-native-nano-icons-example ios -- --mode Release",
    "build:bare:android": "yarn workspace bare-react-native-nano-icons-example android",
    "build:bare:android:release": "yarn workspace bare-react-native-nano-icons-example android -- --mode Release",
    "build:benchmarks:ios": "yarn workspace nano-icons-benchmarking ios",
    "build:benchmarks:ios:release": "yarn workspace nano-icons-benchmarking ios -- --mode Release",
    "build:benchmarks:android": "yarn workspace nano-icons-benchmarking android",
    "build:benchmarks:android:release": "yarn workspace nano-icons-benchmarking android -- --mode Release",
    "start:bare": "yarn workspace bare-react-native-nano-icons-example start",
    "start:expo": "yarn workspace expo-nano-icons-example start",
    "prebuild": "yarn workspace expo-nano-icons-example expo prebuild --clean",
    "test": "yarn workspace react-native-nano-icons test",
    "ts-check": "yarn workspaces foreach --all --parallel --topological-dev run ts-check",
    "lint-js": "yarn workspaces foreach --all --parallel --topological-dev run lint-js",
    "format-js": "yarn workspaces foreach --all --parallel --topological-dev run format-js"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "commitlint": "^19.8.1",
    "eslint": "^10.0.2",
    "eslint-config-satya164": "5.1.8",
    "eslint-import-resolver-babel-module": "^5.3.2",
    "eslint-plugin-jest": "27.4.3",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^8.0.1",
    "jest": "^28.1.0",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
