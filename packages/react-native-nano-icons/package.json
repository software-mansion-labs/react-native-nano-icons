{
  "name": "react-native-nano-icons",
  "version": "0.1.0",
  "description": "Use any svg as font. High-performance, build-time icon font generation for React Native & Expo.",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "bin": "build/scripts/cli.js",
  "main": "./lib/commonjs/index.js",
  "types": "./lib/typescript/commonjs/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "default": "./lib/module/index.js",
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "default": "./lib/commonjs/index.js"
      },
      "bin": "./build/scripts/cli.js",
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      }
    },
    "./app.plugin": "./app.plugin.js",
    "./app.plugin.js": "./app.plugin.js",
    "./package.json": "./package.json"
  },
  "files": [
    "app.plugin.js",
    "build",
    "src/core/shims",
    "bin",
    "src",
    "lib",
    "plugin",
    "scripts"
  ],
  "scripts": {
    "build": "bob build && yarn build:plugin && yarn build:scripts",
    "build:plugin": "tsc -p plugin/tsconfig.json",
    "build:scripts": "tsc -p scripts/tsconfig.json",
    "clean": "del-cli lib build",
    "prepare": "yarn build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest",
    "release": "release-it --only-version",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/config-plugins": ">=9.0.0",
    "fonteditor-core": "^2.6.3",
    "jsdom": "^28.1.0",
    "minimist": "^1.2.8",
    "pathkit-wasm": "^1.0.0",
    "plist": "^3.0.5",
    "pyodide": "^0.29.3",
    "svg2ttf": "^6.0.3",
    "svgicons2svgfont": "^15.0.1",
    "xcode": "^3.0.1"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "@expo/config-plugins": {
      "optional": true
    },
    "expo": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.83.0",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.2.3",
    "@types/plist": "^3.0.5",
    "@types/react": "~19.1.0",
    "@types/svg2ttf": "^5.0.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "commitlint": "^19.8.1",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "expo-module-scripts": "^5.0.8",
    "jest": "^29.7.0",
    "lefthook": "^2.0.3",
    "patch-package": "^8.0.0",
    "prettier": "^2.8.8",
    "react": "19.1.0",
    "react-native": "^0.84.0",
    "react-native-builder-bob": "^0.40.18",
    "release-it": "^19.0.4",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "react-native",
    "expo",
    "react-native-nano-icons",
    "ExpoNanoIcons",
    "RNNanoIcons",
    "ReactNativeNanoIcons",
    "svg-to-ttf",
    "svg2font",
    "svg-to-font",
    "svg-to-ttf",
    "svg-to-glyph"
  ],
  "repository": "https://github.com/stachbial/react-native-nano-icons",
  "bugs": {
    "url": "https://github.com/stachbial/react-native-nano-icons/issues"
  },
  "author": "Stanislaw Bialecki <stanislaw.bialecki@swmansion.com> (https://github.com/stachbial)",
  "license": "MIT",
  "homepage": "https://github.com/stachbial/react-native-nano-icons#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ],
      "commonjs"
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint",
      "jest",
      "lefthook",
      "release-it"
    ],
    "version": "0.57.2"
  }
}
