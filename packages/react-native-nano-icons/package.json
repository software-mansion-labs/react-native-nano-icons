{
  "name": "react-native-nano-icons",
  "version": "0.1.5",
  "description": "Use any svg as font. High-performance, build-time icon font generation and rendering for React Native & Expo.",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "bin": "lib/commonjs/scripts/cli.js",
  "main": "./lib/commonjs/index.node.js",
  "types": "./lib/typescript/src/index.d.ts",
  "files": [
    "app.plugin.js",
    "src/core/shims",
    "bin",
    "src",
    "lib",
    "plugin",
    "scripts",
    "ios",
    "android",
    "react-native-nano-icons.podspec"
  ],
  "scripts": {
    "build": "yarn build:node-entry && bob build && yarn build:core && yarn build:cli && yarn build:plugin && yarn build:scripts",
    "build:node-entry": "tsc -p tsconfig.node.json",
    "build:core": "tsc -p src/core/tsconfig.json",
    "build:cli": "tsc -p cli/tsconfig.json",
    "build:plugin": "tsc -p plugin/tsconfig.json",
    "build:scripts": "tsc -p scripts/tsconfig.json",
    "clean": "del-cli lib",
    "prepare": "yarn build",
    "typecheck": "tsc",
    "ts-check": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "lint-js": "eslint 'src/**/*.{js,ts,tsx}' && prettier --check 'src/**/*.{js,jsx,ts,tsx}'",
    "format-js": "prettier --write --list-different 'src/**/*.{js,jsx,ts,tsx}'",
    "test": "jest"
  },
  "dependencies": {
    "@expo/config-plugins": ">=9.0.0",
    "chalk": "^5.6.2",
    "fonteditor-core": "^2.6.3",
    "jsdom": "^28.1.0",
    "ora": "^9.3.0",
    "pathkit-wasm": "^1.0.0",
    "plist": "^3.0.5",
    "pyodide": "^0.29.3",
    "svg2ttf": "^6.0.3",
    "svgicons2svgfont": "^15.0.1",
    "xcode": "^3.0.1"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "@expo/config-plugins": {
      "optional": true
    },
    "expo": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.83.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.2.3",
    "@types/plist": "^3.0.5",
    "@types/react": "~19.1.0",
    "@types/svg2ttf": "^5.0.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "del-cli": "^6.0.0",
    "expo-module-scripts": "^5.0.8",
    "jest": "^29.7.0",
    "patch-package": "^8.0.0",
    "react": "19.1.0",
    "react-native": "^0.84.0",
    "react-native-builder-bob": "^0.40.18",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "require": {
        "types": "./lib/typescript/src/index.d.ts",
        "default": "./lib/commonjs/index.node.js"
      },
      "import": {
        "types": "./lib/typescript/src/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "default": "./lib/commonjs/index.node.js"
    },
    "./cli": {
      "source": "./cli/index.ts",
      "types": "./lib/commonjs/cli/index.d.ts",
      "require": {
        "default": "./lib/commonjs/cli/index.js"
      }
    },
    "./pipeline": {
      "source": "./src/core/pipeline/index.ts",
      "require": {
        "types": "./lib/commonjs/src/core/pipeline/index.d.ts",
        "default": "./lib/commonjs/src/core/pipeline/index.js"
      }
    },
    "./app.plugin": "./app.plugin.js",
    "./app.plugin.js": "./app.plugin.js",
    "./package.json": "./package.json"
  },
  "keywords": [
    "react-native",
    "expo",
    "react-native-nano-icons",
    "ExpoNanoIcons",
    "RNNanoIcons",
    "ReactNativeNanoIcons",
    "svg-to-ttf",
    "svg2font",
    "svg-to-font",
    "svg-to-ttf",
    "svg-to-glyph"
  ],
  "repository": "https://github.com/software-mansion-labs/react-native-nano-icons",
  "bugs": {
    "url": "https://github.com/software-mansion-labs/react-native-nano-icons/issues"
  },
  "author": "Stanisław Białecki <stanislaw.bialecki@swmansion.com> (https://github.com/stachbial)",
  "license": "MIT",
  "homepage": "https://github.com/software-mansion-labs/react-native-nano-icons#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint",
      "jest",
      "lefthook",
      "release-it"
    ],
    "version": "0.57.2"
  },
  "codegenConfig": {
    "name": "RNNanoIconsSpec",
    "type": "components",
    "jsSrcsDir": "./src/specs",
    "android": {
      "javaPackageName": "com.nanoicons"
    },
    "ios": {
      "components": {
        "NanoIconView": {
          "className": "NanoIconView"
        }
      }
    }
  }
}
